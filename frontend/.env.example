NEXT_PUBLIC_AEGIS_ENV=paseo-beta
NEXT_PUBLIC_PASEO_RPC_URL=https://eth-rpc-testnet.polkadot.io
NEXT_PUBLIC_MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network
NEXT_PUBLIC_AEGIS_VAULT_ADDRESS=0x2BEf17e09b6F9a589d284f62F74281f0580969B3
NEXT_PUBLIC_MOONBASE_STAGING_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WPAS_ADDRESS=0x4F96Fe3b7A6Cf9725f59d353F723c1bDb64CA6Aa
NEXT_PUBLIC_TEST_USDC_ADDRESS=0x8D8b3Eeb22501a37c02c676C25A0F8a9949d0319
NEXT_PUBLIC_MOONBASE_STAGING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOONBASE_STAGING_TOKEN_SYMBOL=mUSDC
DESTINATION_VAULT_ADDRESS=0x9a23A24B7F16d82C75E613bC1ebE9dBEf228d4E6
DEST_PARACHAIN_ID=1000
NEXT_PUBLIC_DOT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x8D8b3Eeb22501a37c02c676C25A0F8a9949d0319
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_ROUTING=false
NEXT_PUBLIC_AEGIS_PRODUCT_INSTRUMENTATION_ENABLED=false
NEXT_PUBLIC_E2E_MOCK_WALLET=false
AI_ORACLE_RELAY_ENABLED=false
# Optional: dedicated signing secret for server-issued instrumentation sessions.
# If unset, instrumentation uses DATABASE_URL or AI_ORACLE_RELAY_DATABASE_URL as a fallback signer secret.
# AEGIS_PRODUCT_INSTRUMENTATION_SECRET=<strong-random-token>
# Internal operator-only dashboard auth:
# AEGIS_LAUNCH_KPI_DASHBOARD_AUTH_TOKEN=<strong-random-token>
XCM_WRAPPER_ASSET_ID=1
# Local prototype / single-service operator work only:
# AI_ORACLE_PRIVATE_KEY=0x<64-hex-chars>
# AI_ORACLE_KEY_VERSION=oracle-paseo-001
# AI_ORACLE_KEY_ROTATED_AT=2026-04-06T00:00:00Z
# AI_ORACLE_RELAY_ALLOW_FILE_STORE=true
# Railway operator deployments should also set:
# AI_ORACLE_RELAY_DATABASE_URL=postgresql://...
# NEXT_PUBLIC_AEGIS_PRODUCT_INSTRUMENTATION_ENABLED=true
# Do not put PRIVATE_KEY, BOOTSTRAP_OWNER_PRIVATE_KEY, or PROOF_WALLET_PRIVATE_KEY in the frontend/Railway service env.
# Optional best-effort operator alerts for relay failures:
# AI_ORACLE_RELAY_ALERT_WEBHOOK_URL=https://...
# AI_ORACLE_ALERT_WEBHOOK_AUTH_TOKEN=<optional-bearer-token>
# AI_ORACLE_ALERT_SOURCE=aegis-paseo-relay
# AI_ORACLE_ALERT_TIMEOUT_MS=3000
# AI_ORACLE_RELAY_ALERT_ENVIRONMENT=railway-staging
# Optional: override the relay request store location.
# AI_ORACLE_RELAY_STORE_PATH=/absolute/path/to/relay-requests.json
