{
  "name": "contracts",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:prototype",
    "test:ci": "node scripts/run-ci-tests.js",
    "test:prototype": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat test test/AegisVault.test.js test/AegisVault.rebalance.test.js",
    "test:launch": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat test test/AegisVaultLaunch.test.js",
    "test:all": "npm run test:prototype && npm run test:launch && npm run test:gas:prototype",
    "test:gas:prototype": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true REPORT_GAS=true hardhat test test/AegisVault.gas.test.js",
    "coverage": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat coverage",
    "gas": "npm run test:gas:prototype",
    "compile": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat compile",
    "deploy": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat run scripts/deploy.js --network paseo",
    "setup": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat run scripts/setup-paseo.js --network paseo",
    "mint": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat run scripts/mint-tokens.js --network paseo",
    "launch:check": "node scripts/launch/check-configs.js",
    "launch:deploy": "node scripts/launch/deploy-launch-contract.js",
    "launch:check-key-posture": "node scripts/launch/check-key-posture.js",
    "launch:prepare": "node scripts/launch/prepare-bootstrap.js",
    "launch:verify": "node scripts/launch/verify-bootstrap.js",
    "launch:prove": "node scripts/launch/prove-vault-flow.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.10.0",
    "hardhat": "^2.28.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.6",
    "@nomicfoundation/hardhat-ethers": "^3.0.6",
    "chai": "^4.3.10",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17"
  }
}
