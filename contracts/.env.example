# Keep separate env files per protected environment (for example,
# `.env.moonbase-staging.local` and `.env.moonbeam-pilot.local`) and copy the
# active one to `.env.local` before running launch commands.
#
# Shared deployer key used by Hardhat prototype scripts and launch deployment.
PRIVATE_KEY=0x<deployer-private-key>

# Set RPC_URL to the active protected launch network before running node-based
# launch scripts such as launch:deploy, launch:prepare, launch:verify, or
# launch:prove. For example:
# - moonbase-staging -> https://rpc.api.moonbase.moonbeam.network
# - moonbeam-pilot  -> https://rpc.api.moonbeam.network
RPC_URL=https://rpc.api.moonbase.moonbeam.network

# Optional network-specific RPC aliases used by Hardhat commands.
PASEO_RPC_URL=https://eth-rpc-testnet.polkadot.io
MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network
MOONBEAM_RPC_URL=https://rpc.api.moonbeam.network

# Active launch profile addresses.
AEGIS_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
AEGIS_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
AEGIS_DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000

# Transitional owner and proof-wallet keys are only needed for protected launch
# operations. Do not place them in frontend or Railway application env files.
BOOTSTRAP_OWNER_PRIVATE_KEY=0x<bootstrap-owner-private-key>
PROOF_WALLET_PRIVATE_KEY=0x<proof-wallet-private-key>

# Rotation metadata required by launch:check-key-posture whenever the matching
# secret is present.
DEPLOYER_KEY_VERSION=launch-deployer-001
DEPLOYER_KEY_ROTATED_AT=2026-04-07T00:00:00Z
BOOTSTRAP_OWNER_KEY_VERSION=launch-bootstrap-owner-001
BOOTSTRAP_OWNER_KEY_ROTATED_AT=2026-04-07T00:00:00Z
PROOF_WALLET_KEY_VERSION=launch-proof-wallet-001
PROOF_WALLET_KEY_ROTATED_AT=2026-04-07T00:00:00Z

# Moonbase staging launch token metadata.
MOONBASE_STAGING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
MOONBASE_STAGING_TOKEN_SYMBOL=mUSDC
